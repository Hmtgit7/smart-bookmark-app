// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

// NOTE: DATABASE_URL (transaction-pooler, port 6543) and DIRECT_URL (direct, port 5432)
// are configured in prisma.config.ts — not here (Prisma 7 requirement).
datasource db {
  provider  = "postgresql"
}

model Bookmark {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id               String    @db.Uuid
  title                 String
  url                   String
  description           String?
  category              String    @default("Uncategorized")
  tags                  String[]
  archived              Boolean   @default(false)
  archived_at           DateTime? @db.Timestamptz
  pinned                Boolean   @default(false)
  pinned_at             DateTime? @db.Timestamptz
  is_private            Boolean   @default(false)
  private_password_hash String?
  created_at            DateTime  @default(now()) @db.Timestamptz

  @@map("bookmarks")
}
